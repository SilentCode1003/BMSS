{
  "name": "sis",
  "version": "1.0.9",
  "private": true,
  "scripts": {
    "prestart": "npm install --save",
    "dev": "nodemon ./bin/www",
    "start": "node ./bin/www",
    "sequelize:init": "sequelize init",
    "db:status": "node ./repository/migrator/migrationsstatus.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:setup": "node ./repository/utility/db.setup.js",
    "db:reset": "npm run db:drop && npm run db:create && npm run db:migrate && npm run db:seed",
    "db:drop": "npx sequelize-cli db:drop",
    "db:create": "npx sequelize-cli db:create",
    "db:seed": "npx sequelize-cli db:seed:all",
    "migrate:undo": "npx sequelize-cli db:migrate:undo"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "bcrypt": "^5.1.0",
    "body-parser": "^1.20.2",
    "chart.js": "^4.3.3",
    "child_process": "^1.0.2",
    "connect-mongodb-session": "^3.1.1",
    "convert-units": "^2.3.4",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "date-fns": "^3.6.0",
    "debug": "~2.6.9",
    "dotenv": "^16.3.1",
    "ejs": "~2.6.1",
    "express": "~4.16.1",
    "express-paginate": "^1.0.2",
    "express-session": "^1.17.3",
    "express-winston": "^4.2.0",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.2",
    "juice": "^10.0.0",
    "moment": "^2.29.4",
    "mongoose": "^7.4.2",
    "morgan": "~1.9.1",
    "mysql": "^2.18.1",
    "mysql2": "^3.10.2",
    "node-linq": "^0.0.5",
    "nodemailer": "^6.9.13",
    "nodemon": "^3.1.2",
    "pdfmake": "^0.2.9",
    "sequelize": "^6.37.5",
    "sequelize-cli": "^6.6.2",
    "sharp": "^0.33.5",
    "socket.io": "^4.7.2",
    "swagger": "^0.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.2",
    "util": "^0.12.5",
    "uuid": "^9.0.1",
    "winston": "^3.10.0"
  }
}
