<div
  class="modal fade"
  id="show-customer-transaction-modal"
  tabindex="-1"
  role="dialog"
  aria-labelledby="exampleModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header custom-bg">
        <h5 class="modal-title" id="exampleModalLabel">Customer Transactions</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="custom-modal-body">
        <div class="card">
          <div class="card-header py-2 header-bg">
            <div class="row">
              <div class="col-md-6">
                <div class="input-group">
                  <div class="input-group-append">
                    <span class="input-group-text" id="basic-addon2">Type</span>
                  </div>
                  <input
                    autocomplete="off"
                    type="text"
                    class="form-control bg-light small"
                    placeholder="Type"
                    aria-label="Type"
                    aria-describedby="basic-addon2"
                    id="show-type-modal"
                    disabled="true"
                  />
                </div>
              </div>

              <div class="col-md-6">
                <div class="input-group">
                  <div class="input-group-append">
                    <span class="input-group-text" id="basic-addon2">Customer</span>
                  </div>
                  <input
                    autocomplete="off"
                    type="text"
                    class="form-control bg-light small"
                    placeholder="Customer"
                    aria-label="Customer"
                    aria-describedby="basic-addon2"
                    id="show-customer-modal"
                    disabled="true"
                  />
                </div>
              </div>
            </div>
          </div>
          <hr>
          <div class="card-body">
            <div class="row">
              <div class="col">
                <div class="table-responsive scroll-cardbody-size-710">
                  <table
                    class="table table-bordered custom-mobile-table"
                    id="customer-transaction-datatable"
                    name="customer-transaction-datatable"
                    width="100%"
                    cellspacing="10"
                  >
                    <thead class="table-header">
                      <tr>
                        <th class="col-1">Sales ID</th>
                        <th class="col-1">Total</th>
                        <th class="col-1">Type</th>
                        <th class="col-1">Customer</th>
                        <th class="col-1">Email</th>
                        <th class="col-1">Address</th>
                      </tr>
                    </thead>
                    <tbody></tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-inventory" id="closeBtn" data-dismiss="modal">
          Close
        </button>
      </div>
    </div>
  </div>
</div>
