<!-- Modal -->
<div
  class="modal fade"
  id="categoryModal"
  tabindex="-1"
  role="dialog"
  aria-labelledby="exampleModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header custom-bg">
        <h5 class="modal-title" id="exampleModalLabel">Category</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="custom-modal-body">
        <div class="card shadow">
          <div class="card-header py-2 header-bg">
            <h6 class="m-0 font-weight-bold table-title">Update Category:</h6>
          </div>
          <div class="card-body">
            <div class="row mb-2">
              <div class="col-md-6">
                <label class="form-label" for="categorycode">Category Code</label>
                <input
                  autocomplete="off"
                  id="categorycode"
                  name="categorycode"
                  type="text"
                  class="form-control"
                  aria-label="categorycode"
                  aria-describedby="basic-addon1"
                  disabled
                />
              </div>
              <div class="col-md-6">
                <label class="form-label" for="currentcategoryname">Current Category Name</label>
                <input
                  autocomplete="off"
                  id="currentcategoryname"
                  name="currentcategoryname"
                  type="text"
                  class="form-control"
                  aria-label="currentcategoryname"
                  aria-describedby="basic-addon1"
                  disabled
                />
              </div>
            </div>
            <div class="row mb-2 justify-content-center">
              <div class="col-md-6">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">Category Name</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="categorynamemodal"
                    name="categorynamemodal"
                    type="text"
                    class="form-control"
                    placeholder="Enter new category name"
                    aria-label="categorynamemodal"
                    aria-describedby="basic-addon1"
                  />
                </div>
              </div>

              <div class="col-md-6">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">isShow</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="isShowModal"
                    name="isShowModal"
                    type="checkbox"
                    class="form-control"
                    placeholder="Enter Is Show Modal"
                    aria-label="isShowModal"
                    aria-describedby="basic-addon1"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-inventory" data-dismiss="modal">Close</button>
        <button type="button" id="updateBtn" class="btn btn-outline-inventory">
          <span id="btn-label-modal">Update</span>
          <span
            id="btnSpinner-modal"
            class="spinner-border spinner-border-sm d-none"
            role="status"
            aria-hidden="true"
          ></span>
        </button>
      </div>
    </div>
  </div>
</div>