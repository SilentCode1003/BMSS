<div class="card">
  <div class="card-header py-3 pb-0 header-bg">
    <h6 class="m-0 font-weight-bold h4 label-title">Add Route</h6>
  </div>
  <div class="card-body extend">
    <div class="row">
      <div class="col-md-6">
        <div class="input-group">
          <div class="input-group-append">
            <span class="input-group-text">Access</span>
          </div>
          <input
            autocomplete="off"
            class="form-control text-center custom-input"
            placeholder="Select Access"
            name="access"
            id="access"
          />
          <input autocomplete="off" type="hidden" id="accessID" name="accessID" />
        </div>
        <div class="custom-dropdown cdw-tableoption" id="accessDropdown"></div>
      </div>
    </div>

    <div class="row mt-4 justify-content-end">
      <div class="col-md-2 justify-content-center md-text-right">
        <button id="addBtn" name="addBtn" class="btn btn-outline-inventory w-100">
          <span id="btnIcon"><i class="fa fa-plus" aria-hidden="true"></i> Add</span>
          <span
            id="btnSpinner"
            class="spinner-border spinner-border-sm d-none"
            role="status"
            aria-hidden="true"
          ></span>
        </button>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header py-3 pb-0 header-bg">
    <div class="progress progress-sm mb-2">
      <div
        class="progress-bar"
        role="progressbar"
        style="width: 0%"
        aria-valuenow="0"
        aria-valuemin="0"
        aria-valuemax="100"
      ></div>
    </div>
    <h6 class="m-0 font-weight-bold h4 label-title">Access Routes Table</h6>
  </div>

  <div class="card-body scroll-cardbody-size-710">
    <div class="row">
      <div class="col-md-6">
        <div class="table-responsive">
          <table
            class="table table-bordered custom-mobile-table"
            id="access-route-dataTable"
            width="100%"
            cellspacing="10"
          >
            <thead class="table-header">
              <tr>
                <th>ID</th>
                <th>Access</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
      <div class="col-md-6">
        <div class="table-responsive">
          <table
            class="table table-bordered custom-mobile-table"
            id="route-dataTable"
            width="100%"
            cellspacing="10"
          >
            <thead class="table-header">
              <tr>
                <th>ID</th>
                <th>Route</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
