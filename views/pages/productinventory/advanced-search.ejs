<!-- Modal -->
<div
  class="modal fade modal-fullscreen-sm-down"
  id="staticBackdrop"
  data-backdrop="static"
  data-keyboard="false"
  tabindex="-1"
  aria-labelledby="staticBackdropLabel"
  aria-hidden="true"
>
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="staticBackdropLabel">Inventory Advanced Search</h1>
        <button type="button" class="btn-close" data-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="row">
          <div class="col-xl-6">
            <h4>Product Category</h4>
            <div id="advanced-search-category">

            </div>
            
          </div>

           <div class="col-xl-6">
            <h4>Product Branch</h4>
            <div id="advanced-search-branch">

            </div>
            
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-outline-inventory w-70 text-center" id="advanced-search-btn">
            <i class="fas fa-search fa-sm"></i>
            <span class="web-hidden">Search</span>
          </button>
          <button class="btn btn-outline-inventory w-70 text-center" id="donwload-pdf-btn">
            <i class="fas fa-download fa-sm"></i>
            <span class="web-hidden">Download to PDF</span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
