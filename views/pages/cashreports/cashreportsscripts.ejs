<script>
  $(document).ready(function () {
    let branch = ''
    let shiftdate = ''
    let posid = ''
    let shift = ''
    let cash_float = ''
    let total_cash = ''
    LoadTable()

    const tbody = $('#cashreport-dataTable tbody')
    TableLoader('#cashreport-dataTable', 12, 7)

    tbody.on('click', 'tr', function () {
      let dataRow = []
      $(this)
        .closest('tr')
        .find('td')
        .each(function () {
          dataRow.push($(this).text())
        })
      //console.log(dataRow);
      branch = dataRow[0]
      shiftdate = dataRow[1]
      posid = dataRow[2]
      shift = dataRow[3]
      cash_float = dataRow[4]
      total_cash = dataRow[5]
    })

    $(document).on('click', '#viewBtn', function () {
      $('#branch').val(branch)
      $('#shiftdate').val(shiftdate)
      $('#posid').val(posid)
      $('#shift').val(shift)
      $('#cashfloat').val(cash_float)
      $('#totalcash').val(total_cash)
      $('#viewModal').modal('show')

      const table = '#denomination-table'
      let denomination = ''
      $.ajax({
        url: '/cashreports/getdenomination',
        method: 'POST',
        data: {
          branch: branch,
          shiftdate: shiftdate,
          posid: posid,
          shift: shift,
        },
        success: function (result) {
          const data = result.data

          console.log(data)

          let denominationTable = data
          const tableBody = $('#denomination-table tbody')
          tableBody.empty()

          if (denominationTable.length === 0) {
            const tr = $('<tr>').append(
              $('<td>', {
                colspan: 3,
                class: 'text-center',
                text: 'No Data Matched',
              })
            )
            tableBody.append(tr)
          } else {
            let index = 0
            let total = 0
            const denominationTableData = denominationTable.map((item) => {
              index++
              const { value, quantity } = item
              return `<tr>
                        <td>${parseFloat(value).toFixed(2)}</td>
                        <td>${quantity}</td>
                        <td>${formatCurrency(
                          parseFloat(quantity).toFixed(2) * parseFloat(value)
                        )}</td>
                      </tr>`

              total += parseFloat(quantity) * parseFloat(value)
            })
            tableBody.append(denominationTableData)
          }
        },
        error: function (err) {
          errormsg(err)
        },
      })
    })

    // $(document).on('click', '#pdfExportBtn', function () {
    //   const data = {
    //     branch: branch,
    //     shiftdate: shiftdate,
    //     posid: posid,
    //     shift: shift,
    //   }
    //   Upsert('POST', '/cashreports/export', data, (result) => {
    //     if (result.msg == 'success') {
    //       window.open(`/pdf/generatepdf`, '_blank')
    //       success('Success', 'PDF generate successfully!')
    //     }
    //   })
    // })

    function populateCashReportTable(data) {
      console.log(data)
      const tableBody = $('#cashreport-dataTable tbody')
      tableBody.empty()

      if (data.length === 0) {
        const tr = $('<tr>').append(
          $('<td>', {
            colspan: 8,
            class: 'text-center',
            text: 'No Data Matched',
          })
        )
        tableBody.append(tr)
      } else {
        data.forEach((item) => {
          let action = `<span class="editbutton mr-2" id="viewBtn" name="viewBtn" data-toggle="modal" data-target="#viewModal"><i class="fas fa-eye" style="color: rgb(99, 115, 129);"></i></span>`
          const tr = $('<tr>').append(
            $('<td>', {
              text: item.branch_name,
              'data-label': 'Report ID',
              class: 'custom-mobile-align',
            }),
            $('<td>', {
              text: item.shift_date,
              'data-label': 'Date',
              class: 'custom-mobile-align',
            }),
            $('<td>', { text: item.pos_id, 'data-label': 'Shift', class: 'custom-mobile-align' }),
            $('<td>', { text: item.shift, 'data-label': 'POS', class: 'custom-mobile-align' }),
            $('<td>', {
              text: formatCurrency(item.cash_float),
              'data-label': 'Cashier',
              class: 'custom-mobile-align',
            }),
            $('<td>', {
              text: formatCurrency(item.total_cash),
              'data-label': 'Type',
              class: 'custom-mobile-align',
            }),

            $('<td>', { html: action, 'data-label': 'Action' })
          )

          tableBody.append(tr)
        })
      }
    }

    function LoadTable() {
      $('.progress').hide()
      $('.progress').slideDown()

      $.ajax({
        url: '/cashreports/getcashreport',
        method: 'GET',
        dataType: 'json',
        xhrFields: {
          onprogress: function (e) {
            if (e.lengthComputable) {
              var percentComplete = (e.loaded / e.total) * 100
              $('.progress-bar').css('width', percentComplete + '%')
            }
          },
        },
        success: function (data) {
          setTimeout(function () {
            $('.progress').slideUp(function () {
              if (data.message === 'success') {
                populateCashReportTable(data.data)
              } else {
                console.error(data.msg)
              }
            })
          }, 1000)
        },
        error: function (error) {
          console.error(error)
        },
      })
    }

    function filterTableRows() {
      const searchQuery = $('#search-input').val().trim().toLowerCase()
      let foundMatches = false

      $('#no-match-row').remove()

      $('#cashreport-dataTable tbody tr').each(function () {
        const rowData = $(this).text().toLowerCase()
        if (rowData.includes(searchQuery)) {
          $(this).show()
          foundMatches = true
        } else {
          $(this).hide()
        }
      })

      if (!foundMatches) {
        const noMatchRow = $('<tr>').append(
          $('<td>', {
            colspan: 9,
            class: 'text-center',
            text: 'No Data Matched',
          })
        )
        $('#cashreport-dataTable tbody').append(noMatchRow)
        noMatchRow.attr('id', 'no-match-row')
      }
    }

    $('#search-input').on('input', filterTableRows)

    $(document).on('click', '.applyBtn', function () {
      //console.log(dateRange);
      refreshData()
    })

    //#region Date Ranger Picker
    $('#dateRange').daterangepicker({
      opens: 'right',
      startDate: moment(), //@add .subtract(7, 'days') for weekly view
      endDate: moment(),
      maxDate: moment(),
      alwaysShowCalendars: true,
      showCustomRangeLabel: false,
      buttonClasses: ['btn btn-outline-inventory'],
      applyButtonClasses: ['test'],
      locale: {
        format: 'MMM D, YYYY',
      },
    })

    $('#adjustDateBackward').on('click', function () {
      var startDate = $('#dateRange').data('daterangepicker').startDate
      var endDate = $('#dateRange').data('daterangepicker').endDate.clone().subtract(7, 'days')
      $('#dateRange').data('daterangepicker').setEndDate(endDate)
      $('#dateRange').data('daterangepicker').setStartDate(startDate.clone().subtract(7, 'days'))

      refreshData()
    })

    $('#adjustDateForward').on('click', function () {
      var startDate = $('#dateRange').data('daterangepicker').startDate
      var endDate = $('#dateRange').data('daterangepicker').endDate.clone().add(7, 'days')
      $('#dateRange').data('daterangepicker').setStartDate(startDate.clone().add(7, 'days'))
      $('#dateRange').data('daterangepicker').setEndDate(endDate)

      refreshData()
    })

    function refreshData() {
      let dateRange = $('#dateRange').val()
      let date = formatDate(dateRange)

      console.log(date)

      Fetch(`/cashreports/filter/${date}`, (result) => {
        populateCashReportTable(result.data)
      })
    }
    //#endregion

    //#region Date Formatting
    function formatDate(date) {
      let startDate = moment(date.split(' - ')[0], 'MMM D, YYYY').format('YYYY-MM-DD')
      let endDate = moment(date.split(' - ')[1], 'MMM D, YYYY').format('YYYY-MM-DD')
      let formattedDate = startDate + ' - ' + endDate

      return formattedDate
    }
    //#endregion
  })
</script>
