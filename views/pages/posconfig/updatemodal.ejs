<!-- Modal -->
<div
  class="modal fade"
  id="editModal"
  tabindex="-1"
  role="dialog"
  aria-labelledby="exampleModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header custom-bg">
        <h5 class="modal-title" id="exampleModalLabel">Denomination</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="custom-modal-body">
        <div class="card shadow">
          <div class="card-header py-2 header-bg">
            <h6 class="m-0 font-weight-bold table-title">Update Denomination:</h6>
          </div>
          <div class="card-body">
            <div class="row mb-2">
              <div class="col-md-6">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">ID</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="idmodal"
                    name="idmodal"
                    type="text"
                    class="form-control"
                    aria-label="idmodal"
                    aria-describedby="basic-addon1"
                    disabled
                  />
                </div>
              </div>

              <div class="col-md-6 mmb">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">POS</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="posmodal"
                    name="posmodal"
                    type="text"
                    class="form-control"
                    placeholder="Select/Input POS"
                    aria-label="posmodal"
                    aria-describedby="basic-addon1"
                  />
                  <input autocomplete="off" type="hidden" id="posmodalID" name="posmodalID" />
                </div>
                <div class="custom-dropdown cdw-tableoption" id="posmodalDropdown"></div>
              </div>
            </div>
            <div class="row mb-2">
              <div class="col-md-6">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">POS Printer IP</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="posprinteripmodal"
                    name="posprinteripmodal"
                    type="text"
                    class="form-control"
                    placeholder="e.g 192.168.1.100"
                    aria-label="posprinteripmodal"
                    aria-describedby="basic-addon1"
                    oninput="IPAddressOnly(this, 'posprinteripmodal')"
                  />
                </div>
              </div>
              <div class="col-md-6">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2"
                      >Production/Kitchen Printer IP</span
                    >
                  </div>
                  <input
                    autocomplete="off"
                    id="productionprinteripmodal"
                    name="productionprinteripmodal"
                    type="text"
                    class="form-control"
                    placeholder="e.g 192.168.1.100"
                    aria-label="productionprinteripmodal"
                    aria-describedby="basic-addon1"
                    oninput="IPAddressOnly(this, 'productionprinteripmodal')"
                  />
                </div>
              </div>
            </div>

            <div class="row mb-2">
              <div class="col-md-6 mmb">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">Printer Name</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="printernamemodal"
                    name="printernamemodal"
                    type="text"
                    class="form-control"
                    placeholder="Enter Printer Name"
                    aria-label="printernamemodal"
                    aria-describedby="basic-addon1"
                  />
                </div>
              </div>
              <div class="col-md-6">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">Paper Size</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="papersizemodal"
                    name="papersizemodal"
                    type="text"
                    class="form-control"
                    placeholder="Enter Denomination Description"
                    aria-label="papersizemodal"
                    aria-describedby="basic-addon1"
                  />
                  <input autocomplete="off" type="hidden" id="papersizemodalID" name="papersizemodalID" />
                </div>
                <div class="custom-dropdown cdw-tableoption" id="papersizemodalDropdown"></div>
              </div>
            </div>

            <div class="row mb-2">
              <div class="col-md-4">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">Enable Printer</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="isprintermodal"
                    name="isprintermodal"
                    type="checkbox"
                    class="form-control"
                    aria-label="isprintermodal"
                    aria-describedby="basic-addon1"
                  />
                </div>
              </div>

              <div class="col-md-4">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">Enable Cashdrawer</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="iscashdrawermodal"
                    name="iscashdrawermodal"
                    type="checkbox"
                    class="form-control"
                    aria-label="iscashdrawermodal"
                    aria-describedby="basic-addon1"
                  />
                </div>
              </div>

              <div class="col-md-4">
                <div class="input-group">
                  <div class="input-group-prepend">
                    <span class="input-group-text" id="basic-addon2">Enable Bluetooth</span>
                  </div>
                  <input
                    autocomplete="off"
                    id="isblutoothmodal"
                    name="isblutoothmodal"
                    type="checkbox"
                    class="form-control"
                    aria-label="isblutoothmodal"
                    aria-describedby="basic-addon1"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" id="closeBtn" class="btn btn-outline-inventory" data-dismiss="modal">
          Close
        </button>
        <button type="button" id="updateBtn" class="btn btn-outline-inventory">
          <span id="btn-label-modal">Update</span>
          <span
            id="btnSpinner-modal"
            class="spinner-border spinner-border-sm d-none"
            role="status"
            aria-hidden="true"
          ></span>
        </button>
      </div>
    </div>
  </div>
</div>
