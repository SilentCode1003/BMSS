<!-- Modal -->
<div
  class="modal fade"
  id="editModal"
  tabindex="-1"
  role="dialog"
  aria-labelledby="exampleModalLabel"
  aria-hidden="true"
>
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header custom-bg">
        <h5 class="modal-title" id="exampleModalLabel">Denomination</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="custom-modal-body">
        <div class="card shadow">
          <div class="card-header py-2 header-bg">
            <h6 class="m-0 font-weight-bold table-title">Update Denomination:</h6>
          </div>
          <div class="card-body">
            <div class="row mb-2 justify-content-center">
              <div class="col-md-6">
                <label class="form-label">Denomination ID: </label>
                <input
                  autocomplete="off"
                  id="idmodal"
                  name="idmodal"
                  type="text"
                  class="form-control"
                  aria-label="fullname"
                  aria-describedby="basic-addon1"
                  disabled
                />
              </div>
            </div>
            <div class="row mb-2">
              <div class="col-md-6">
                <label class="form-label">Denomination Code: </label>
                <input
                  autocomplete="off"
                  id="codemodal"
                  name="codemodal""
                  placeholder="Enter New Denomination Code"
                  type="text"
                  class="form-control"
                  aria-label="fullname"
                  aria-describedby="basic-addon1"
                />
              </div>
              <div class="col-md-6">
                <label class="form-label">Description: </label>
                <input
                  autocomplete="off"
                  id="descriptionmodal"
                  name="descriptionmodal"
                  placeholder="Enter New Description"
                  type="text"
                  class="form-control"
                  aria-label="fullname"
                  aria-describedby="basic-addon1"
                />
              </div>
            </div>
            <div class="row mb-2 justify-content-center">
              <div class="col-md-6">
                <label class="form-label">Value: </label>
                <input
                  autocomplete="off"
                  id="valuemodal"
                  name="valuemodal"
                  placeholder="Enter New Value"
                  type="text"
                  class="form-control"
                  aria-label="fullname"
                  aria-describedby="basic-addon1"
                  oninput="formatPrice(event, this)"
                />
              </div>

            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" id="closeBtn" class="btn btn-outline-inventory" data-dismiss="modal">
          Close
        </button>
        <button type="button" id="updateBtn" class="btn btn-outline-inventory">
          <span id="btn-label-modal">Update</span>
          <span
            id="btnSpinner-modal"
            class="spinner-border spinner-border-sm d-none"
            role="status"
            aria-hidden="true"
          ></span>
        </button>
      </div>
    </div>
  </div>
</div>
